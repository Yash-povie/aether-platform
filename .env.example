# PostgreSQL
DATABASE_URL=postgresql+asyncpg://aether:aether@postgres:5432/aether
POSTGRES_USER=aether
POSTGRES_PASSWORD=aether
POSTGRES_DB=aether

# Redis
REDIS_URL=redis://redis:6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aether-artifacts
MINIO_SECURE=false

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=aether-embeddings

# JWT — generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private_key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public_key
JWT_ALGORITHM=RS256
JWT_EXPIRE_MINUTES=60

# LLM APIs
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=aether

# App
APP_ENV=development
LOG_LEVEL=INFO
HITL_CONFIDENCE_THRESHOLD=0.75
